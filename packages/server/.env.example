# Server
PORT=4000
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:5173

# Database
DATABASE_URL=postgresql://collabboard:collabboard@localhost:5432/collabboard?schema=public

# Auth
JWT_ACCESS_SECRET=change-this-access-secret-in-production
JWT_REFRESH_SECRET=change-this-refresh-secret-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# AI
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4o-mini
