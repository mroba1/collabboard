# Used by docker-compose.yml when running `docker compose up`.
# Copy this file to `.env` in the repo root and fill in real values.

JWT_ACCESS_SECRET=change-this-access-secret-in-production
JWT_REFRESH_SECRET=change-this-refresh-secret-in-production
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4o-mini
